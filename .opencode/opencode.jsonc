{
  "$schema": "https://opencode.ai/config.json",
//==========================================
  "mcp": {

    "supabase": {
      "type": "remote",
      "url": "https://mcp.supabase.com/mcp",
      "enabled": true
    },

    "shadcn": {
      "type": "local",
      "command": [
        "npx",
        "shadcn@latest",
        "mcp"
      ],
      "enabled": true
    },

    "TestSprite": {
      "type": "local",
      "command": ["npx", "@testsprite/testsprite-mcp@latest"],
      "environment": {
        "API_KEY": "${TESTSPRITE_API_KEY}",
       }
     },

     "context7": {
       "type": "remote",
       "url": "https://mcp.context7.com/mcp"
     },
    
     "resend": {
       "type": "local",
       "command": ["npx", "-y", "resend-mcp"],
       "enabled": true,
       "environment": {
          "RESEND_API_KEY": "${RESEND_API_KEY}"
       }
     }
  }
  
}
